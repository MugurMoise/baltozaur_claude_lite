# Copy this file to .env for local development.
# Local .env files are intentionally ignored by git.

# Use dev locally and in Vercel Preview/Development.
# Use prod in Vercel Production.
VITE_APP_ENV=dev

# Same Supabase project for dev and prod.
# The app uses dev_* tables when VITE_APP_ENV=dev.
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# VAPID keys for Web Push - generate with: npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=your_vapid_public_key_here
