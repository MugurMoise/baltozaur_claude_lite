# Copy this file to .env for local development.
# Local .env files are intentionally ignored by git.

# For local/dev work, point these at your Supabase dev branch.
# For Vercel Production, point them at your Supabase production branch.
VITE_SUPABASE_URL=your_supabase_branch_url
VITE_SUPABASE_ANON_KEY=your_supabase_branch_anon_key

# VAPID keys for Web Push - generate with: npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=your_vapid_public_key_here
